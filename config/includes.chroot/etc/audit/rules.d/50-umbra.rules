# Umbra OS — auditd baseline ruleset.
-D
-b 8192
-f 1

## Identity & privilege
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/group -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/sudoers -p wa -k privilege
-w /etc/sudoers.d/ -p wa -k privilege
-w /etc/pam.d/ -p wa -k privilege

## Login records
-w /var/log/faillog -p wa -k logins
-w /var/log/lastlog -p wa -k logins

## MAC policy
-w /etc/apparmor/ -p wa -k mac-policy
-w /etc/apparmor.d/ -p wa -k mac-policy

## Kernel modules
-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -k modules
-w /etc/modprobe.d/ -p wa -k modules

## Mounts
-a always,exit -F arch=b64 -S mount -F auid>=1000 -F auid!=unset -k mounts

## Time
-a always,exit -F arch=b64 -S adjtimex,settimeofday,clock_settime -k time-change
-w /etc/localtime -p wa -k time-change

## Network environment (incl. opsec-relevant configs)
-w /etc/hosts -p wa -k network
-w /etc/resolv.conf -p wa -k network
-w /etc/nftables.conf -p wa -k network
-w /etc/tor/ -p wa -k tor
-w /etc/NetworkManager/ -p wa -k network

## Privileged execution
-a always,exit -F arch=b64 -S execve -C uid!=euid -F euid=0 -k setuid-exec

## Failed access
-a always,exit -F arch=b64 -S open,openat,openat2 -F exit=-EACCES -F auid>=1000 -F auid!=unset -k access-denied
-a always,exit -F arch=b64 -S open,openat,openat2 -F exit=-EPERM -F auid>=1000 -F auid!=unset -k access-denied

## Deletions
-a always,exit -F arch=b64 -S unlink,unlinkat,rename,renameat -F auid>=1000 -F auid!=unset -k delete

## Admin files
-w /etc/ssh/sshd_config -p wa -k sshd
-w /etc/ssh/sshd_config.d/ -p wa -k sshd
-w /etc/crontab -p wa -k cron
-w /etc/cron.d/ -p wa -k cron
