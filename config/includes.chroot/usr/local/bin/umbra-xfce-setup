#!/bin/bash
# Umbra OS — first-login wallpaper safety net for Xfce.
# The full look (theme, panel, whisker menu, wallpaper) ships as static config in
# /etc/skel/.config/xfce4. This ONLY re-asserts the wallpaper on whatever monitor
# names actually exist on this host (VMs/GPUs name them differently), then reloads
# the desktop. It never touches the panel — that's what broke it before.
set -u
marker="${HOME}/.config/umbra-xfce-done"
[ -f "$marker" ] && exit 0
WP="/usr/share/backgrounds/umbra/wallpaper.png"

# wait for xfconfd to be answering
for _ in 1 2 3 4 5 6 7 8; do xfconf-query -c xfce4-desktop -l >/dev/null 2>&1 && break; sleep 1; done

# set the wallpaper on every backdrop property that actually exists
for prop in $(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep -E '/last-image$'); do
    xfconf-query -c xfce4-desktop -p "$prop" -s "$WP" 2>/dev/null || true
    st="${prop%/last-image}/image-style"
    xfconf-query -c xfce4-desktop -p "$st" -s 5 2>/dev/null || true
done
xfdesktop --reload 2>/dev/null &

mkdir -p "${HOME}/.config"
touch "$marker"
exit 0
