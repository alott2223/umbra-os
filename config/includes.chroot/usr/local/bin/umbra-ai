#!/bin/bash
# Umbra OS — AI control surface. A small, predictable API so AI/automation agents
# can SEE the screen (screenshot / accessibility tree) and ACT on it (click, type,
# keys, window focus, run commands). Network surfaces (VNC/SSH) are OPT-IN so the
# hardened default keeps a minimal attack surface.
#
#   umbra ai screenshot [file]   capture the screen (PNG); prints the path
#   umbra ai screen              print screen geometry (WxH)
#   umbra ai cursor              print current pointer position
#   umbra ai move  <x> <y>       move the pointer
#   umbra ai click <x> <y> [btn] click at x,y (btn 1=left 2=mid 3=right)
#   umbra ai type  <text...>     type text into the focused window
#   umbra ai key   <keys>        press keys, xdotool syntax (e.g. ctrl+l, Return)
#   umbra ai windows             list open windows (id · title) + active window
#   umbra ai focus <title>       raise/focus a window by title substring
#   umbra ai tree                dump the accessibility (AT-SPI) UI tree
#   umbra ai exec  <cmd...>      run a shell command, print its output
#   umbra ai vnc {on|off|status} [--lan]   remote screen (localhost by default)
#   umbra ai ssh {on|off|status}           remote shell (opt-in)
#   umbra ai status              show capabilities + VNC/SSH state
set -uo pipefail

# When invoked over SSH there is no DISPLAY; target the local seat :0 and find the
# active user's X authority so xdotool/scrot can reach the running desktop.
export DISPLAY="${DISPLAY:-:0}"
if [ -z "${XAUTHORITY:-}" ]; then
    for x in "$HOME/.Xauthority" /home/*/.Xauthority /run/user/*/gdm/Xauthority \
             /var/run/lightdm/root/:0 /run/lightdm/*/xauthority; do
        [ -f "$x" ] && export XAUTHORITY="$x" && break
    done
fi
have(){ command -v "$1" >/dev/null 2>&1; }
Y=$'\033[1;33m'; G=$'\033[1;32m'; R=$'\033[1;31m'; N=$'\033[0m'
need_root(){ [[ $EUID -eq 0 ]] || { echo -e "${Y}needs sudo:${N} sudo umbra ai $*"; exit 1; }; }

shot(){
    local out="${1:-$HOME/umbra-ai-$(date +%s).png}"
    if have scrot; then scrot -o "$out"
    elif have maim; then maim "$out"
    elif have import; then import -window root "$out"
    else echo "no screenshot tool"; exit 1; fi
    echo "$out"
}

cmd="${1:-status}"; shift 2>/dev/null || true
case "$cmd" in
  screenshot|shot) shot "${1:-}" ;;
  screen)  xdotool getdisplaygeometry | tr ' ' 'x' ;;
  cursor)  xdotool getmouselocation --shell | grep -E '^(X|Y)=' | cut -d= -f2 | paste -sd, - ;;
  move)    xdotool mousemove "$1" "$2"; echo "moved $1,$2" ;;
  click)   xdotool mousemove "$1" "$2" click "${3:-1}"; echo "clicked $1,$2 btn ${3:-1}" ;;
  type)    xdotool type --clearmodifiers -- "$*"; echo "typed ${#*} chars" ;;
  key)     xdotool key --clearmodifiers "$@"; echo "key $*" ;;
  windows)
    echo "# id · desktop · title"; wmctrl -l 2>/dev/null | awk '{$2="";print}'
    echo "# active: $(xdotool getactivewindow getwindowname 2>/dev/null)" ;;
  focus)   wmctrl -a "$*" && echo "focused: $*" || { xdotool search --name "$*" windowactivate 2>/dev/null && echo "focused: $*"; } ;;
  tree)
    if have python3; then
      python3 - <<'PY' 2>/dev/null || echo "AT-SPI unavailable (is a desktop session running?)"
import pyatspi
def walk(o, d=0):
    try:
        role = o.getRoleName(); name = o.name or ""
    except Exception:
        return
    if d <= 3 and (name or role in ("frame","dialog","push button","menu item","page tab")):
        print("  "*d + f"[{role}] {name}")
    for i in range(o.childCount):
        try: walk(o.getChildAtIndex(i), d+1)
        except Exception: pass
for app in pyatspi.Registry.getDesktop(0):
    if app and app.childCount:
        print(f"== {app.name} ==")
        walk(app, 0)
PY
    else echo "python3 missing"; fi ;;
  exec)    "$@" ;;
  vnc)
    sub="${1:-status}"; lan=""; [ "${2:-}" = "--lan" ] && lan="1"
    case "$sub" in
      on)  need_root vnc on
           bind="-localhost"; [ -n "$lan" ] && bind=""
           echo "starting x11vnc on display :0 ${bind:+(localhost only)}"
           echo -e "${Y}set a VNC password:${N}"; x11vnc -storepasswd /etc/umbra-vnc.pass
           x11vnc -display :0 -auth guess -rfbauth /etc/umbra-vnc.pass -forever -shared $bind -bg -o /var/log/umbra-vnc.log
           echo -e "${G}VNC up${N} on :5900 ${bind:+(tunnel via: ssh -L 5900:localhost:5900 <host>)}" ;;
      off) need_root vnc off; pkill -x x11vnc 2>/dev/null; echo "VNC stopped" ;;
      *)   pgrep -x x11vnc >/dev/null && echo "VNC: running" || echo "VNC: off" ;;
    esac ;;
  ssh)
    sub="${1:-status}"
    case "$sub" in
      on)  need_root ssh on; systemctl enable --now ssh 2>/dev/null || systemctl enable --now sshd
           echo -e "${G}SSH enabled${N} — agents can now: ssh user@<host> 'umbra ai screenshot'" ;;
      off) need_root ssh off; systemctl disable --now ssh 2>/dev/null || systemctl disable --now sshd; echo "SSH disabled" ;;
      *)   systemctl is-active ssh >/dev/null 2>&1 && echo "SSH: active" || echo "SSH: off" ;;
    esac ;;
  status)
    echo "Umbra AI control surface"
    for t in xdotool wmctrl scrot import x11vnc python3; do
        have "$t" && echo "  ok   $t" || echo "  --   $t (missing)"
    done
    have python3 && python3 -c "import pyatspi" 2>/dev/null && echo "  ok   AT-SPI accessibility tree" || echo "  --   AT-SPI"
    pgrep -x x11vnc >/dev/null && echo "  VNC: running" || echo "  VNC: off (umbra ai vnc on)"
    systemctl is-active ssh >/dev/null 2>&1 && echo "  SSH: active" || echo "  SSH: off (umbra ai ssh on)"
    echo "  DISPLAY=$DISPLAY  XAUTHORITY=${XAUTHORITY:-<unset>}" ;;
  *) echo "unknown: umbra ai $cmd (try: umbra ai status)"; exit 1 ;;
esac
