#!/bin/bash
# Umbra OS — unified cyber-security command center.
#   umbra <command> [args]      ·   run 'umbra' with no args for the menu
# Defensive / audit / opsec tooling only.
set -uo pipefail

P=$'\033[1;35m'; C=$'\033[1;36m'; G=$'\033[1;32m'; Y=$'\033[1;33m'; R=$'\033[1;31m'; D=$'\033[0;90m'; N=$'\033[0m'
hr(){ printf "${D}%s${N}\n" "────────────────────────────────────────────────────────"; }
head(){ printf "\n${P}▛▀ %s${N}\n" "$1"; }
need_root(){ [[ $EUID -eq 0 ]] || { echo -e "${Y}this needs sudo:${N} sudo umbra $*"; exit 1; }; }
have(){ command -v "$1" >/dev/null 2>&1; }

menu(){
cat <<EOF

${P}  ██╗   ██╗███╗   ███╗██████╗ ██████╗  █████╗ ${N}   security command center
${P}  ██║   ██║████╗ ████║██╔══██╗██╔══██╗██╔══██╗${N}
${P}  ╚██████╔╝██║ ╚═╝ ██║██████╔╝██║  ██║██║  ██║${N}   umbra <command>

${C}AUDIT & DETECTION${N}
   umbra verify        prove the hardening controls are active
   umbra audit         full audit: verify + rootkit + integrity + updates
   umbra scan <path>   malware scan a file/folder (ClamAV)
   umbra integrity     file-integrity check vs. AIDE baseline
   umbra rootkit       run rkhunter + chkrootkit
   umbra logins        recent logins + failed attempts

${C}NETWORK & EXPOSURE${N}
   umbra net           exposure summary (IP, MAC, DNS, ports, Tor)
   umbra ports         listening ports + owning processes
   umbra ip            public IP + whether it exits via Tor
   umbra tor {on|off|status}   Tor transparent kill-switch
   umbra mac           re-randomize your MAC address now
   umbra firewall      show the active nftables ruleset

${C}DATA & PRIVACY${N}
   umbra scrub <file>  strip metadata (EXIF/doc) before sharing
   umbra wipe <file>   securely erase a file (unrecoverable)
   umbra hash <file>   sha256 fingerprint for integrity
   umbra lock          lock the screen now

${C}MAINTENANCE & EMERGENCY${N}
   umbra updates       apply security updates
   umbra panic         emergency: cut net, wipe keys, power off
   umbra hardened-malloc   enable the hardened memory allocator

EOF
}

cmd="${1:-menu}"; shift 2>/dev/null || true
case "$cmd" in
  menu|help|-h|--help) menu ;;

  verify)   exec umbra-verify.sh "$@" ;;
  panic)    exec umbra-panic "$@" ;;
  tor)      exec umbra-torswitch "$@" ;;
  hardened-malloc) exec umbra-hardened-malloc.sh "$@" ;;

  audit)
    head "1/4 hardening verification"; sudo umbra-verify.sh || true
    head "2/4 rootkit scan (rkhunter)"; sudo rkhunter --check --sk --nocolors 2>/dev/null | grep -Ei 'warning|infected|rootkit' || echo "  no warnings"
    head "3/4 file integrity (AIDE)"; if [[ -f /var/lib/aide/aide.db ]]; then sudo aide --check 2>/dev/null | tail -8; else echo "  no AIDE baseline yet (run: sudo umbra integrity --init)"; fi
    head "4/4 pending security updates"; apt-get -s upgrade 2>/dev/null | grep -c '^Inst.*security' | sed 's/^/  security updates available: /'
    ;;

  scan)
    [[ $# -ge 1 ]] || { echo "usage: umbra scan <file|dir>"; exit 1; }
    have clamscan || { echo "clamav not installed"; exit 1; }
    head "ClamAV scan: $*"; clamscan -r --bell -i "$@"
    ;;

  integrity)
    need_root integrity
    if [[ "${1:-}" == "--init" ]]; then head "building AIDE baseline"; aideinit --yes --force; else
      [[ -f /var/lib/aide/aide.db ]] || { echo "no baseline. run: sudo umbra integrity --init"; exit 1; }
      head "AIDE integrity check"; aide --check; fi
    ;;

  rootkit)
    need_root rootkit
    head "rkhunter"; rkhunter --check --sk --nocolors 2>/dev/null | grep -Ei 'warning|infected|rootkit|checking for' | tail -20
    head "chkrootkit"; have chkrootkit && chkrootkit -q 2>/dev/null || echo "  chkrootkit not installed"
    ;;

  logins)
    head "recent successful logins"; last -n 10 2>/dev/null | head -10
    head "recent FAILED logins"; sudo lastb -n 10 2>/dev/null | head -10 || echo "  (need sudo)"
    head "account lockouts (faillock)"; have faillock && sudo faillock 2>/dev/null | head -20 || true
    ;;

  net)
    head "identity"; echo "  host : $(hostname)"; for i in $(ls /sys/class/net | grep -v lo); do echo "  mac  : $i $(cat /sys/class/net/$i/address 2>/dev/null)"; done
    head "DNS"; resolvectl status 2>/dev/null | grep -E 'DNS Servers|DNSOverTLS|Current DNS' | sed 's/^/  /' || cat /etc/resolv.conf | sed 's/^/  /'
    head "listening ports"; ss -tulpnH 2>/dev/null | awk '{print "  "$1"  "$5}' | sort -u | head -20
    head "Tor kill-switch"; umbra-torswitch status 2>/dev/null | head -3 || echo "  off"
    head "public IP"; "$0" ip
    ;;

  ports)
    head "listening TCP/UDP ports + process"; ss -tulpn 2>/dev/null || sudo ss -tulpn
    ;;

  ip)
    if have curl; then
      r=$(curl -s --max-time 15 https://check.torproject.org/api/ip 2>/dev/null || true)
      if [[ "$r" == *IsTor* ]]; then
        istor=$(echo "$r" | grep -o '"IsTor":[a-z]*' | cut -d: -f2)
        pip=$(echo "$r" | grep -o '"IP":"[^"]*"' | cut -d'"' -f4)
        if [[ "$istor" == "true" ]]; then echo -e "  ${G}via Tor${N}  exit IP: $pip"; else echo -e "  ${Y}clear net${N}  public IP: $pip"; fi
      else echo "  could not reach check.torproject.org (offline?)"; fi
    fi
    ;;

  mac)
    need_root mac
    for i in $(ls /sys/class/net | grep -Ev 'lo|tun|tap'); do
      old=$(cat /sys/class/net/$i/address)
      ip link set dev "$i" down 2>/dev/null && macchanger -r "$i" >/dev/null 2>&1 && ip link set dev "$i" up 2>/dev/null
      echo "  $i: $old -> $(cat /sys/class/net/$i/address)"
    done
    echo "  (NetworkManager may re-apply its own randomized MAC on reconnect)"
    ;;

  firewall)
    head "active nftables ruleset"; sudo nft list ruleset 2>/dev/null | sed 's/^/  /' | head -60
    ;;

  scrub)
    [[ $# -ge 1 ]] || { echo "usage: umbra scrub <file>"; exit 1; }
    have mat2 || { echo "mat2 not installed"; exit 1; }
    echo "metadata found:"; mat2 --show "$@"; echo; mat2 "$@" && echo "cleaned -> ${1%.*}.cleaned.${1##*.}"
    ;;

  wipe)
    [[ $# -ge 1 ]] || { echo "usage: umbra wipe <file>  (UNRECOVERABLE)"; exit 1; }
    read -rp "Securely erase '$1'? this cannot be undone [y/N] " a; [[ "$a" == y ]] || exit 0
    if have srm; then srm -v "$@"; else shred -vzu -n 3 "$@"; fi; echo "wiped."
    ;;

  hash)
    [[ $# -ge 1 ]] || { echo "usage: umbra hash <file>"; exit 1; }
    sha256sum "$@"
    ;;

  lock) exec i3lock -n -c 05070d ;;

  updates)
    need_root updates
    head "applying security updates"; apt-get update && apt-get -y upgrade
    ;;

  *) echo "unknown command: $cmd"; menu; exit 1 ;;
esac
